# Архитектурный контракт:
# .env.production — создаётся CI/CD перед сборкой (npm run build)
# VITE_API_BASE_URL НЕ ДОЛЖЕН содержать пути вида /v1 — backend НЕ использует префикс
VITE_API_BASE_URL=https://api.f639.luxury
VITE_TELEGRAM_BOT_TOKEN=
VITE_ADMIN_CHAT_IDS=
# На проде моки ВЫКЛ — если API упало, ошибка видна пользователю
VITE_API_FALLBACK_TO_MOCKS=false
